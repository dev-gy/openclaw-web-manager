# ============================================================
# OpenClaw Web Manager — Development Dockerfile
# ============================================================

FROM node:22-alpine

WORKDIR /app

# OpenClaw Gateway 설치
COPY gateway/ /opt/openclaw/
RUN cd /opt/openclaw && npm install --omit=dev \
  && printf '#!/bin/sh\ncd /opt/openclaw && exec node cli.js "$@"\n' > /usr/local/bin/openclaw \
  && chmod +x /usr/local/bin/openclaw

# OWM 의존성 설치 (레이어 캐싱)
COPY package.json package-lock.json ./
RUN npm ci

# 소스코드는 docker-compose에서 볼륨 마운트
EXPOSE 3000

CMD ["node", "node_modules/vite/bin/vite.js"]
